# Chọn nhà cung cấp: mock | twilio | stringee | telegram
PROVIDER=mock

# Cổng server
PORT=3000

# Đồng bộ đa thiết bị (bố + mẹ): gửi push qua Expo.
# PUSH_DRY_RUN=true để không gửi thật (dùng khi dev/test).
PUSH_DRY_RUN=false
# Nơi lưu sổ đăng ký thiết bị (mặc định ./data/families.json).
# FAMILY_STORE=/var/data/families.json

# Token app dùng để gọi tới server (Bearer). App phải gửi Authorization: Bearer <token>.
# KHÔNG dùng khoá Twilio/Stringee làm token này.
API_KEY=doi-thanh-token-bi-mat-cua-ban

# ---- Twilio (khi PROVIDER=twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # số Twilio gửi đi, dạng E.164 vd +1xxxxxxxxxx

# ---- Stringee (khi PROVIDER=stringee) ----
STRINGEE_API_SID=
STRINGEE_API_SECRET=
STRINGEE_FROM_NUMBER=        # số Stringee đã đăng ký để gọi ra
STRINGEE_SMS_ENABLED=false   # SMS Stringee cần brandname được duyệt; bật khi đã có

# ---- Telegram (khi PROVIDER=telegram) — MIỄN PHÍ, không cần Twilio/Stringee ----
TELEGRAM_BOT_TOKEN=          # lấy từ @BotFather
TELEGRAM_CHAT_ID=            # id group/chat của bố mẹ (từ getUpdates)
TELEGRAM_DRY_RUN=false       # true để test không gửi thật

# ---- Dữ liệu xe kết nối: mock | smartcar ----
VEHICLE_PROVIDER=mock
SMARTCAR_CLIENT_ID=
SMARTCAR_CLIENT_SECRET=
SMARTCAR_REDIRECT_URI=       # vd https://your-server/vehicle/callback
SMARTCAR_MODE=live           # live | test | simulated
# Khoá mã hoá token xe khi lưu (bất kỳ chuỗi bí mật nào). Bỏ trống = lưu thô (chỉ dev).
TOKEN_ENC_KEY=
